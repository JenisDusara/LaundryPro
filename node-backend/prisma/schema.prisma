generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Admin {
  id                  String    @id @default(uuid())
  username            String    @unique
  password_hash       String
  name                String
  shop_id             String    @default("shop1")
  shop_name           String    @default("My Shop")
  role                String    @default("admin")
  is_active           Boolean   @default(true)
  token_version       Int       @default(0)
  must_change_password Boolean  @default(false)
  plan_type           String?   // "monthly" | "yearly"
  expires_at          DateTime?
  created_at          DateTime  @default(now())
  setup_token         String?   @unique // legacy signup setup token; public signup is disabled
  setup_token_expires DateTime?

  @@map("admins")
}

model ShopProfile {
  id         String   @id @default(uuid())
  shop_id    String   @unique
  shop_name  String   @default("")
  tagline    String   @default("")
  phone      String   @default("")
  address    String   @default("")
  email      String   @default("")
  upi_id     String   @default("")
  gst_number String   @default("")
  gst_rate   Float    @default(0) // GST % shown on invoice tax line; 0 = no tax line
  invoice_terms       String @default("Garments held 30 days · not responsible for colour bleed or shrinkage")
  footer_note         String @default("Thank you for your business")
  default_labour_rate Float  @default(2) // pre-fills the labour work rate (₹/piece)
  logo_data  String?  @db.Text // base64 data-URL, embedded in invoice header
  weekly_report_enabled Boolean @default(true) // auto-email the Sunday weekly report to `email`
  wa_auto_enabled       Boolean @default(false) // auto-send a WhatsApp bill on new entry (via WA-Service)
  wa_show_prices        Boolean @default(true) // when false, WhatsApp bills show only items
  qr_show_full_phone    Boolean @default(false)
  qr_show_full_address  Boolean @default(false)
  qr_show_order_notes   Boolean @default(true)
  qr_pending_expiry_days Int    @default(90)
  qr_delivery_expiry_hours Int  @default(2)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("shop_profiles")
}

model WeeklyReportLog {
  id         String   @id @default(uuid())
  shop_id    String
  week_start String
  week_end   String
  status     String   // "sent" | "skipped" | "failed"
  reason     String   @default("")
  created_at DateTime @default(now())

  @@index([shop_id])
  @@index([created_at])
  @@map("weekly_report_logs")
}

model Customer {
  id           String         @id @default(uuid())
  name         String
  phone        String
  flat_number  String         @default("")
  society_name String         @default("")
  address      String         @default("")
  email        String?
  billing_type String         @default("per_order") // "per_order" | "monthly"
  shop_id      String         @default("shop1")
  deleted_at   DateTime?
  deleted_by   String         @default("")
  deleted_by_username String  @default("")
  delete_reason String        @default("")
  created_at   DateTime       @default(now())
  updated_at   DateTime       @updatedAt
  entries      LaundryEntry[]
  payments     Payment[]

  @@unique([phone, shop_id])
  @@index([shop_id])
  @@index([deleted_at])
  @@map("customers")
}

model Payment {
  id          String   @id @default(uuid())
  customer_id String
  customer    Customer @relation(fields: [customer_id], references: [id])
  amount      Decimal  @db.Decimal(10, 2)
  method      String   @default("cash") // "cash" | "upi" | "card" | "other"
  date        String   // YYYY-MM-DD (payment received date, IST)
  note        String   @default("")
  shop_id     String   @default("shop1")
  received_by String   @default("")   // user id who recorded the payment
  received_by_username String @default("") // their username, shown in payment history
  deleted_at  DateTime?
  deleted_by  String   @default("")
  deleted_by_username String @default("")
  delete_reason String @default("")
  created_at  DateTime @default(now())

  @@index([shop_id])
  @@index([customer_id])
  @@index([date])
  @@index([deleted_at])
  @@map("payments")
}

model Service {
  id         String      @id @default(uuid())
  name       String
  parent_id  String?
  parent     Service?    @relation("ServiceChildren", fields: [parent_id], references: [id])
  children   Service[]   @relation("ServiceChildren")
  price       Decimal?   @db.Decimal(10, 2)
  category    String?    // POS catalog filter: MEN | WOMEN | KIDS | HOUSEHOLD | INSTITUTIONAL | OTHERS
  description String?    // optional free-text note, useful for "OTHERS" category items
  is_active  Boolean     @default(true)
  shop_id    String      @default("shop1")
  created_at DateTime    @default(now())
  updated_at DateTime    @updatedAt
  items      EntryItem[]

  @@index([shop_id])
  @@map("services")
}

model LaundryEntry {
  id              String      @id @default(uuid())
  customer_id     String
  customer        Customer    @relation(fields: [customer_id], references: [id])
  entry_date      String
  total_amount    Decimal     @db.Decimal(10, 2)
  delivery_status String      @default("pending")
  notes           String      @default("")
  delivery_date   String?
  // Billing columns — previously created only via scripts/add-billing-columns.sql and read/written
  // through raw SQL because they weren't declared here (schema drift). Now declared so the Prisma
  // client is typed for them, `prisma db push` keeps them in sync, and future migrations are clean.
  invoice_no      Int?        // per-shop running bill number (starts at 1)
  discount        Decimal     @default(0) @db.Decimal(10, 2)
  extra_charge    Decimal     @default(0) @db.Decimal(10, 2)
  amount_paid     Decimal     @default(0) @db.Decimal(10, 2)
  payment_method  String      @default("")
  // QR tag columns — a scannable garment tag points at /t/<qr_token>. qr_token is a random,
  // globally-unique token (NOT the entry id) so the public scan URL can't be guessed from an
  // adjacent order. tag_notes is the shop's free-text note printed on the tag and shown on the
  // scan page (e.g. "red border saree, stain on sleeve"). Both are nullable/defaulted and read
  // via raw SQL until `prisma generate` runs, matching the delivery_date / billing pattern.
  qr_token        String?     @unique
  tag_notes       String      @default("")
  tag_mode        String      @default("order") // "order" | "stickers" | "item"
  // Operational workflow state shown/updated on the scan page: "collected" | "in_process" |
  // "ready" | "delivered" | "issue". This is a superset of the billing-facing delivery_status
  // (which stays "pending"/"delivered" so reports/accounting are untouched). The two are kept
  // in sync at exactly one point: tag_status = "delivered" ⟺ delivery_status = "delivered".
  tag_status      String      @default("collected")
  // Timestamp of the last transition to delivered. Drives the tag's auto-expiry: the scan API
  // refuses to show details once 2 hours have passed since this, so a photographed/lost tag
  // stops working shortly after the order is handed over. Cleared when delivery is reverted.
  delivered_at    DateTime?
  shop_id         String      @default("shop1")
  deleted_at      DateTime?
  deleted_by      String      @default("")
  deleted_by_username String  @default("")
  delete_reason   String      @default("")
  created_at      DateTime    @default(now())
  updated_at      DateTime    @updatedAt
  items           EntryItem[]
  item_tags       EntryItemTag[]

  @@index([entry_date])
  @@index([shop_id])
  @@index([deleted_at])
  @@map("laundry_entries")
}

model EntryItem {
  id             String       @id @default(uuid())
  entry_id       String
  entry          LaundryEntry @relation(fields: [entry_id], references: [id], onDelete: Cascade)
  service_id     String
  service        Service      @relation(fields: [service_id], references: [id])
  service_name   String
  price_per_unit Decimal      @db.Decimal(10, 2)
  quantity       Int
  delivered_qty  Int          @default(0) // how many of `quantity` have been handed over (partial delivery)
  subtotal       Decimal      @db.Decimal(10, 2)
  item_status    String       @default("pending") // kept in sync: "delivered" once delivered_qty >= quantity
  item_tags      EntryItemTag[]

  @@map("entry_items")
}

// True garment-level tags for "item" tag mode. An EntryItem of quantity N (e.g. "Saree ×5")
// expands into N rows here — one physical sticker per garment, each with its own unguessable
// token — so "Saree 3/5" can be scanned/tracked individually. Only populated when a tag is
// generated in item mode; order/stickers modes use LaundryEntry.qr_token instead.
model EntryItemTag {
  id            String       @id @default(uuid())
  entry_id      String
  entry         LaundryEntry @relation(fields: [entry_id], references: [id], onDelete: Cascade)
  entry_item_id String
  item          EntryItem    @relation(fields: [entry_item_id], references: [id], onDelete: Cascade)
  seq           Int          // 1..quantity, printed as "3/5"
  qr_token      String       @unique
  label         String       @default("") // optional per-garment note, e.g. "red border"
  created_at    DateTime     @default(now())

  @@index([entry_id])
  @@index([entry_item_id])
  @@unique([entry_item_id, seq])
  @@map("entry_item_tags")
}

model QrTagEvent {
  id         String   @id @default(uuid())
  entry_id   String
  shop_id    String
  token      String   @default("")
  action     String
  status     String   @default("")
  mode       String   @default("")
  detail     String   @default("")
  user_id    String   @default("")
  username   String   @default("")
  ip         String   @default("")
  created_at DateTime @default(now())

  @@index([entry_id, created_at])
  @@index([shop_id, created_at])
  @@map("qr_tag_events")
}

model QrRevokedToken {
  token      String   @id
  entry_id   String
  shop_id    String
  reason     String   @default("")
  revoked_by String   @default("")
  username   String   @default("")
  revoked_at DateTime @default(now())

  @@index([entry_id])
  @@index([shop_id])
  @@map("qr_revoked_tokens")
}

model QrScanAttempt {
  id           String   @id @default(uuid())
  token_prefix String   @default("")
  shop_id      String   @default("")
  user_id      String   @default("")
  username     String   @default("")
  ip           String   @default("")
  reason       String
  created_at   DateTime @default(now())

  @@index([ip, created_at])
  @@index([shop_id, created_at])
  @@map("qr_scan_attempts")
}

model Labour {
  id         String          @id @default(uuid())
  name       String
  is_active  Boolean         @default(true)
  shop_id    String          @default("shop1")
  created_at DateTime        @default(now())
  works      LabourWork[]
  advances   LabourAdvance[]
  payments   LabourPayment[]

  @@index([shop_id])
  @@map("labours")
}

model LabourWork {
  id             String   @id @default(uuid())
  labour_id      String
  labour         Labour   @relation(fields: [labour_id], references: [id])
  work_date      String
  press_count    Int
  rate_per_piece Decimal  @default(2) @db.Decimal(10, 2)
  deleted_at     DateTime?
  deleted_by     String   @default("")
  deleted_by_username String @default("")
  delete_reason  String   @default("")
  created_at     DateTime @default(now())

  // One work row per labourer per day — the POST handler upserts on this, so concurrent
  // submits can't create duplicate rows that double-count the labourer's pay.
  @@unique([labour_id, work_date])
  @@index([deleted_at])
  @@map("labour_work")
}

model LabourAdvance {
  id           String   @id @default(uuid())
  labour_id    String
  labour       Labour   @relation(fields: [labour_id], references: [id])
  advance_date String
  amount       Decimal  @db.Decimal(10, 2)
  description  String   @default("")
  expense_id   String   @default("") // linked expense row, so deletion stays reconciled
  deleted_at   DateTime?
  deleted_by   String   @default("")
  deleted_by_username String @default("")
  delete_reason String  @default("")
  created_at   DateTime @default(now())

  @@index([deleted_at])
  @@map("labour_advances")
}

model LabourPayment {
  id           String   @id @default(uuid())
  labour_id    String
  labour       Labour   @relation(fields: [labour_id], references: [id])
  period       String   @default("") // YYYY-MM the payout settles
  pay_date     String
  amount       Decimal  @db.Decimal(10, 2)
  method       String   @default("cash") // cash | upi | card | other
  note         String   @default("")
  shop_id      String   @default("shop1")
  paid_by      String   @default("")
  paid_by_username String @default("")
  expense_id   String   @default("") // linked expense row, so deletion stays reconciled
  deleted_at   DateTime?
  created_at   DateTime @default(now())

  @@index([shop_id])
  @@index([labour_id])
  @@index([pay_date])
  @@map("labour_payments")
}

model LoginLog {
  id         String   @id @default(uuid())
  username   String
  name       String   @default("")
  shop_id    String   @default("")
  shop_name  String   @default("")
  role       String   @default("admin")
  status     String   // "success" | "failed"
  reason     String   @default("")
  ip         String   @default("")
  created_at DateTime @default(now())

  @@index([shop_id])
  @@index([created_at])
  @@map("login_logs")
}

model SuperadminActionLog {
  id              String   @id @default(uuid())
  actor_id        String
  actor_username  String
  action          String
  target_admin_id String   @default("")
  target_shop_id  String   @default("")
  target_shop_name String  @default("")
  metadata        Json?
  ip              String   @default("")
  created_at      DateTime @default(now())

  @@index([actor_id])
  @@index([target_shop_id])
  @@index([action])
  @@index([created_at])
  @@map("superadmin_action_logs")
}

model DataActionLog {
  id                String   @id @default(uuid())
  actor_id          String
  actor_username    String
  actor_role        String
  shop_id           String
  action            String
  entity_type       String
  entity_id         String
  entity_label      String   @default("")
  metadata          Json?
  ip                String   @default("")
  created_at        DateTime @default(now())

  @@index([shop_id])
  @@index([action])
  @@index([entity_type])
  @@index([entity_id])
  @@index([created_at])
  @@map("data_action_logs")
}

model Expense {
  id          String   @id @default(uuid())
  date        String
  category    String
  description String   @default("")
  amount      Decimal  @db.Decimal(10, 2)
  shop_id     String   @default("shop1")
  deleted_at  DateTime?
  deleted_by  String   @default("")
  deleted_by_username String @default("")
  delete_reason String @default("")
  created_at  DateTime @default(now())

  @@index([shop_id])
  @@index([date])
  @@index([deleted_at])
  @@map("expenses")
}

// Legacy public signup leads. Public signup is disabled; clients are now created
// manually by superadmin with a temporary password.
model SignupRequest {
  id          String    @id @default(uuid())
  shop_name   String
  owner_name  String
  phone       String
  email       String
  city        String    @default("")
  status      String    @default("pending") // "pending" | "approved" | "rejected"
  ip          String    @default("")
  created_at  DateTime  @default(now())
  reviewed_at DateTime?

  @@index([status])
  @@index([created_at])
  @@map("signup_requests")
}
