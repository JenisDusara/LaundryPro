generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Admin {
  id                  String    @id @default(uuid())
  username            String    @unique
  password_hash       String
  name                String
  shop_id             String    @default("shop1")
  shop_name           String    @default("My Shop")
  role                String    @default("admin")
  is_active           Boolean   @default(true)
  plan_type           String?   // "monthly" | "yearly"
  expires_at          DateTime?
  created_at          DateTime  @default(now())
  setup_token         String?   @unique // pending "choose your username/password" link after signup-request approval
  setup_token_expires DateTime?

  @@map("admins")
}

model ShopProfile {
  id         String   @id @default(uuid())
  shop_id    String   @unique
  shop_name  String   @default("")
  tagline    String   @default("")
  phone      String   @default("")
  address    String   @default("")
  email      String   @default("")
  upi_id     String   @default("")
  gst_number String   @default("")
  gst_rate   Float    @default(0) // GST % shown on invoice tax line; 0 = no tax line
  invoice_terms       String @default("Garments held 30 days · not responsible for colour bleed or shrinkage")
  footer_note         String @default("Thank you for your business")
  default_labour_rate Float  @default(2) // pre-fills the labour work rate (₹/piece)
  logo_data  String?  @db.Text // base64 data-URL, embedded in invoice header
  weekly_report_enabled Boolean @default(true) // auto-email the Sunday weekly report to `email`
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("shop_profiles")
}

model WeeklyReportLog {
  id         String   @id @default(uuid())
  shop_id    String
  week_start String
  week_end   String
  status     String   // "sent" | "skipped" | "failed"
  reason     String   @default("")
  created_at DateTime @default(now())

  @@index([shop_id])
  @@index([created_at])
  @@map("weekly_report_logs")
}

model Customer {
  id           String         @id @default(uuid())
  name         String
  phone        String
  flat_number  String         @default("")
  society_name String         @default("")
  address      String         @default("")
  email        String?
  shop_id      String         @default("shop1")
  created_at   DateTime       @default(now())
  updated_at   DateTime       @updatedAt
  entries      LaundryEntry[]
  payments     Payment[]

  @@unique([phone, shop_id])
  @@index([shop_id])
  @@map("customers")
}

model Payment {
  id          String   @id @default(uuid())
  customer_id String
  customer    Customer @relation(fields: [customer_id], references: [id])
  amount      Decimal  @db.Decimal(10, 2)
  method      String   @default("cash") // "cash" | "upi" | "card" | "other"
  date        String   // YYYY-MM-DD (payment received date, IST)
  note        String   @default("")
  shop_id     String   @default("shop1")
  created_at  DateTime @default(now())

  @@index([shop_id])
  @@index([customer_id])
  @@index([date])
  @@map("payments")
}

model Service {
  id         String      @id @default(uuid())
  name       String
  parent_id  String?
  parent     Service?    @relation("ServiceChildren", fields: [parent_id], references: [id])
  children   Service[]   @relation("ServiceChildren")
  price      Decimal?    @db.Decimal(10, 2)
  is_active  Boolean     @default(true)
  shop_id    String      @default("shop1")
  created_at DateTime    @default(now())
  updated_at DateTime    @updatedAt
  items      EntryItem[]

  @@index([shop_id])
  @@map("services")
}

model LaundryEntry {
  id              String      @id @default(uuid())
  customer_id     String
  customer        Customer    @relation(fields: [customer_id], references: [id])
  entry_date      String
  total_amount    Decimal     @db.Decimal(10, 2)
  delivery_status String      @default("pending")
  notes           String      @default("")
  delivery_date   String?
  shop_id         String      @default("shop1")
  created_at      DateTime    @default(now())
  updated_at      DateTime    @updatedAt
  items           EntryItem[]

  @@index([entry_date])
  @@index([shop_id])
  @@map("laundry_entries")
}

model EntryItem {
  id             String       @id @default(uuid())
  entry_id       String
  entry          LaundryEntry @relation(fields: [entry_id], references: [id], onDelete: Cascade)
  service_id     String
  service        Service      @relation(fields: [service_id], references: [id])
  service_name   String
  price_per_unit Decimal      @db.Decimal(10, 2)
  quantity       Int
  delivered_qty  Int          @default(0) // how many of `quantity` have been handed over (partial delivery)
  subtotal       Decimal      @db.Decimal(10, 2)
  item_status    String       @default("pending") // kept in sync: "delivered" once delivered_qty >= quantity

  @@map("entry_items")
}

model Labour {
  id         String          @id @default(uuid())
  name       String
  is_active  Boolean         @default(true)
  shop_id    String          @default("shop1")
  created_at DateTime        @default(now())
  works      LabourWork[]
  advances   LabourAdvance[]

  @@index([shop_id])
  @@map("labours")
}

model LabourWork {
  id             String   @id @default(uuid())
  labour_id      String
  labour         Labour   @relation(fields: [labour_id], references: [id])
  work_date      String
  press_count    Int
  rate_per_piece Decimal  @default(2) @db.Decimal(10, 2)
  created_at     DateTime @default(now())

  // One work row per labourer per day — the POST handler upserts on this, so concurrent
  // submits can't create duplicate rows that double-count the labourer's pay.
  @@unique([labour_id, work_date])
  @@map("labour_work")
}

model LabourAdvance {
  id           String   @id @default(uuid())
  labour_id    String
  labour       Labour   @relation(fields: [labour_id], references: [id])
  advance_date String
  amount       Decimal  @db.Decimal(10, 2)
  description  String   @default("")
  created_at   DateTime @default(now())

  @@map("labour_advances")
}

model LoginLog {
  id         String   @id @default(uuid())
  username   String
  name       String   @default("")
  shop_id    String   @default("")
  shop_name  String   @default("")
  role       String   @default("admin")
  status     String   // "success" | "failed"
  reason     String   @default("")
  ip         String   @default("")
  created_at DateTime @default(now())

  @@index([shop_id])
  @@index([created_at])
  @@map("login_logs")
}

model Expense {
  id          String   @id @default(uuid())
  date        String
  category    String
  description String   @default("")
  amount      Decimal  @db.Decimal(10, 2)
  shop_id     String   @default("shop1")
  created_at  DateTime @default(now())

  @@index([shop_id])
  @@index([date])
  @@map("expenses")
}

// Public "Start free trial" leads from the marketing site. Superadmin reviews
// and either approves (creates the actual Admin/ShopProfile) or rejects each
// one; approved + rejected rows stay around as a marketing contact list.
model SignupRequest {
  id          String    @id @default(uuid())
  shop_name   String
  owner_name  String
  phone       String
  email       String
  city        String    @default("")
  status      String    @default("pending") // "pending" | "approved" | "rejected"
  ip          String    @default("")
  created_at  DateTime  @default(now())
  reviewed_at DateTime?

  @@index([status])
  @@index([created_at])
  @@map("signup_requests")
}

