# ─────────────────────────────────────────────────────────────────────────────
# LaundryPro — environment variables
# Copy this file to `.env` and fill in real values. NEVER commit the real `.env`
# (it is gitignored). Values below are placeholders only.
# ─────────────────────────────────────────────────────────────────────────────

# ── Required ────────────────────────────────────────────────────────────────

# PostgreSQL connection string (Neon in production).
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Secret used to sign/verify JWT session tokens. MUST be a long random string.
# In production the app refuses to start without it. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
SECRET_KEY="change-me-to-a-long-random-string"

# ── Email (invoices, weekly reports, signup notifications) ───────────────────
# The mailbox the app sends from. For a custom domain email like info@laundrymax.in,
# set EMAIL_HOST/EMAIL_PORT to your provider's SMTP settings (see below). If EMAIL_HOST
# is left blank the app falls back to Gmail (treats EMAIL_USER/PASS as a Gmail account
# + App Password).
EMAIL_USER="info@laundrymax.in"
EMAIL_PASS="your-mailbox-password"

# SMTP server for the custom domain mailbox. This project uses GoDaddy email, which is
# powered by Titan (see "POWERED BY TITAN" in the webmail):
#   GoDaddy / Titan Email      → EMAIL_HOST=smtp.titan.email          EMAIL_PORT=465
# Other GoDaddy variants, in case yours differs:
#   GoDaddy Professional Email → EMAIL_HOST=smtpout.secureserver.net  EMAIL_PORT=465
#   GoDaddy Microsoft 365      → EMAIL_HOST=smtp.office365.com        EMAIL_PORT=587
# Leave EMAIL_HOST blank to use plain Gmail instead.
EMAIL_HOST="smtp.titan.email"
EMAIL_PORT="465"

# Optional display name shown to recipients (defaults to "LaundryMax").
EMAIL_FROM_NAME="LaundryMax"

# Where new "Start free trial" signup-request notifications are sent.
# Falls back to EMAIL_USER if unset.
ADMIN_NOTIFY_EMAIL="owner@yourbusiness.com"

# ── Optional integrations ─────────────────────────────────────────────────────

# SMS via Fast2SMS. Leave unset/blank to disable SMS (the app no-ops gracefully).
FAST2SMS_API_KEY=""

# WhatsApp auto-send service (Baileys). Leave WA_SERVICE_URL unset to disable
# WhatsApp auto-bills. WA_SHARED_SECRET must match the WA service's secret.
WA_SERVICE_URL=""
WA_SHARED_SECRET=""

# Shared secret required (as the `x-cron-secret` header) to trigger the weekly
# report cron endpoint. Set the same value in the Netlify scheduled function.
CRON_SECRET="change-me"

# ── Public (exposed to the browser) ──────────────────────────────────────────
NEXT_PUBLIC_APP_NAME="LaundryPro"

# Public base URL of the deployed app. Used to build the QR tag scan links
# (https://<PUBLIC_APP_URL>/t/<token>) so a phone camera opens the live site.
# Leave blank locally — the app then derives the origin from the request host.
# No trailing slash.
PUBLIC_APP_URL="https://your-live-domain.com"
